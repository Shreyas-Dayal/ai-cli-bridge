# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3456

# ─── Admin Key (REQUIRED for production) ──────────────────────────────────────
# Controls all /admin/* endpoints (key management, logs, etc.)
# Generate with: openssl rand -hex 32
# If empty, admin endpoints will reject all requests.
BRIDGE_ADMIN_KEY=

# ─── Data ─────────────────────────────────────────────────────────────────────
# Directory for keys.json, usage.json, and logs.json.
# Created automatically if it doesn't exist. Files are written with 0o600 perms.
DATA_DIR=./data

# ─── Rate Limiting (global) ──────────────────────────────────────────────────
# Applies to ALL requests regardless of API key.
# Default: 30 requests per 60 seconds.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
#   Example: https://myapp.com,https://staging.myapp.com
#   Empty = allow ALL origins (fine for local dev, NOT recommended for production)
CORS_ORIGINS=

# ─── Claude Code CLI ─────────────────────────────────────────────────────────
# Default model when none is specified in the request body.
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514

# Max time (ms) to wait for the CLI to respond. Increase for complex prompts.
CLAUDE_TIMEOUT_MS=120000

# Max stdout buffer size (bytes). 10MB default. Increase if output is truncated.
CLAUDE_MAX_BUFFER_BYTES=10485760

# ─── Codex CLI ────────────────────────────────────────────────────────────────
# Default model when none is specified in the request body.
CODEX_DEFAULT_MODEL=gpt-5.3-codex

# Max time (ms) to wait for the CLI to respond.
CODEX_TIMEOUT_MS=180000

# Max stdout buffer size (bytes).
CODEX_MAX_BUFFER_BYTES=10485760
