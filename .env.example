# Server
PORT=3456

# Admin key for /admin/* endpoints (key management).
# Generate with: openssl rand -hex 32
BRIDGE_ADMIN_KEY=

# Data directory for keys.json and usage.json
DATA_DIR=./data

# Rate limiting (global, applies to all keys)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# CORS — comma-separated allowed origins. Empty = allow all.
CORS_ORIGINS=

# Claude Code CLI defaults
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT_MS=120000
CLAUDE_MAX_BUFFER_BYTES=10485760

# Codex CLI defaults
CODEX_DEFAULT_MODEL=gpt-5.3-codex
CODEX_TIMEOUT_MS=180000
CODEX_MAX_BUFFER_BYTES=10485760
