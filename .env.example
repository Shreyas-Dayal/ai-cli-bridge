# Server
PORT=3456

# Authentication — comma-separated list of valid API keys for callers.
# If empty, auth is disabled (local dev mode).
# Generate keys with: openssl rand -hex 32
BRIDGE_API_KEYS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# CORS — comma-separated allowed origins. Empty = allow all.
CORS_ORIGINS=

# Claude Code CLI defaults
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT_MS=120000
CLAUDE_MAX_BUFFER_BYTES=10485760

# Codex CLI defaults
CODEX_DEFAULT_MODEL=gpt-5.3-codex
CODEX_TIMEOUT_MS=180000
CODEX_MAX_BUFFER_BYTES=10485760
